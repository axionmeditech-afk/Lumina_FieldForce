PORT=5000
JWT_SECRET=replace-with-strong-random-secret

# MySQL
MYSQL_HOST=your-mysql-host
MYSQL_PORT=3306
MYSQL_USER=your-mysql-user
MYSQL_PASSWORD=your-mysql-password
MYSQL_DATABASE=your-mysql-database
MYSQL_SSL=false
MYSQL_SSL_REJECT_UNAUTHORIZED=false

# Field-force route tracking retention
# Keep raw GPS points recent and bounded; route views downsample for display.
LOCATION_LOG_RETENTION_DAYS=14
LOCATION_LOG_MAX_ROWS=50000
LOCATION_LOG_OVERFLOW_MIN_KEEP_DAYS=2
LOCATION_LOG_DELETE_BATCH_SIZE=5000
LOCATION_LOG_PRUNE_INTERVAL_MS=3600000
EXPO_PUBLIC_FIELD_FORCE_LOCATION_INTERVAL_MS=15000
EXPO_PUBLIC_FIELD_FORCE_LOCATION_DISTANCE_METERS=5
EXPO_PUBLIC_ROUTE_TRACKING_REFRESH_MS=5000
EXPO_PUBLIC_ATTENDANCE_REFRESH_MS=5000
EXPO_PUBLIC_AUTO_CHECKOUT_ON_GEOFENCE_EXIT=true
AUTO_CHECKOUT_ON_GEOFENCE_EXIT=true

# Optional service keys
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-20b
SPEECH_TO_TEXT_PROVIDER_ORDER=google
MAX_TRANSCRIBE_AUDIO_MB=350
GOOGLE_CREDENTIALS=
GOOGLE_CLOUD_STORAGE_BUCKET=
GOOGLE_TIMEOUT_MS=900000
GOOGLE_STT_PHRASE_HINTS=Axion Meditech,Axion,doctor,hospital,clinic,distributor,stockist,quotation,follow up,purchase order
GOOGLE_STT_PHRASE_BOOST=12
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash-lite
GROQ_STT_MODEL=whisper-large-v3
EXPO_PUBLIC_SALES_AI_STT_PROVIDER_ORDER=google
EXPO_PUBLIC_SALES_AI_STT_MODEL=gemini-2.5-flash-lite
EXPO_PUBLIC_SALES_AI_STT_LANGUAGE_CODE=en-IN
EXPO_PUBLIC_SALES_AI_TRANSCRIBE_CHUNK_MS=15000
DOLIBARR_ENDPOINT=
DOLIBARR_API_KEY=
DOLIBARR_USER_AGENT=LuminaFieldForce/1.0 (+https://api.axionmeditech.com)
MAPPLS_ROUTING_API_KEY=

# Field tracking map provider: google, osm, maptiler, or mappls.
EXPO_PUBLIC_MAP_PROVIDER=google
# Google Maps native SDK key used at Android APK build time.
GOOGLE_MAPS_API_KEY=
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=
