{
  "expo": {
    "name": "Lumina FieldForce",
    "slug": "trackforce-ai",
    "entryPoint": "./node_modules/expo-router/entry",
    "version": "1.0.0",
    "updates": {
      "checkAutomatically": "NEVER",
      "fallbackToCacheTimeout": 0
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "trackforceai",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-lumina.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.trackforceai"
    },
    "android": {
      "package": "com.trackforceai",
      "permissions": [
        "POST_NOTIFICATIONS",
        "VIBRATE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0F172A",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      }
    },
    "web": {
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-notifications",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Lumina FieldForce uses your location to verify geo-fenced attendance at your assigned branch.",
          "locationAlwaysAndWhenInUsePermission": "Lumina FieldForce uses your location in background to prevent attendance spoofing and keep secure logs.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Lumina FieldForce needs microphone access to record and transcribe sales conversations.",
          "speechRecognitionPermission": "Lumina FieldForce uses speech recognition to convert recorded conversations into transcripts.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox",
            "com.google.android.as"
          ]
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Lumina FieldForce requires camera access for live attendance selfie verification."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
