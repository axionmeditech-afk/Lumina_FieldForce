{
  "expo": {
    "name": "Lumina FieldForce",
    "slug": "lumina-fieldforce",
    "owner": "appallakarthik",
    "entryPoint": "./node_modules/expo-router/entry",
    "version": "1.0.0",
    "updates": {
      "enabled": false,
      "checkAutomatically": "NEVER",
      "fallbackToCacheTimeout": 0
    },
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "luminafieldforce",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.luminafieldforce",
      "buildNumber": "15",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "location",
          "audio"
        ]
      },
      "config": {
        "googleMapsApiKey": "YOUR_GOOGLE_MAPS_IOS_API_KEY"
      }
    },
    "android": {
      "package": "com.luminafieldforce",
      "versionCode": 6,
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "FOREGROUND_SERVICE_MICROPHONE",
        "REQUEST_IGNORE_BATTERY_OPTIMIZATIONS",
        "RECORD_AUDIO",
        "POST_NOTIFICATIONS",
        "WAKE_LOCK",
        "VIBRATE"
      ],
      "adaptiveIcon": {
        "backgroundColor": "#0F172A",
        "foregroundImage": "./assets/images/logo.png"
      },
      "config": {
        "googleMaps": {
          "apiKey": "YOUR_GOOGLE_MAPS_ANDROID_API_KEY"
        }
      }
    },
    "web": {
      "favicon": "./assets/images/logo.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-web-browser",
      "expo-notifications",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Lumina FieldForce uses Face ID to securely verify your identity for attendance."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Lumina FieldForce uses your location to verify geo-fenced attendance at your assigned branch.",
          "locationAlwaysAndWhenInUsePermission": "Lumina FieldForce uses your location in background to prevent attendance spoofing and keep secure logs.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Lumina FieldForce needs microphone access to record and transcribe sales conversations.",
          "speechRecognitionPermission": "Lumina FieldForce uses speech recognition to convert recorded conversations into transcripts.",
          "androidSpeechServicePackages": [
            "com.google.android.googlequicksearchbox",
            "com.google.android.as"
          ]
        }
      ],
      [
        "expo-image-picker",
        {
          "cameraPermission": "Lumina FieldForce requires camera access for live attendance selfie verification."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "671331d1-e438-4593-9fda-8a71075988f7"
      }
    }
  }
}
