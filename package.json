{
  "name": "expo-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "postinstall": "patch-package",
    "expo:dev": "set EXPO_NO_DOCTOR=1&& node ./node_modules/expo/bin/cli start --android",
    "android": "node ./node_modules/expo/bin/cli run:android",
    "ios": "node ./node_modules/expo/bin/cli run:ios",
    "start:lan": "set EXPO_NO_DOCTOR=1&& node ./node_modules/expo/bin/cli start --host lan --port 8081",
    "start:tunnel": "set EXPO_NO_DOCTOR=1&& node ./node_modules/expo/bin/cli start --tunnel",
    "start:web": "set EXPO_NO_DOCTOR=1&& node ./node_modules/expo/bin/cli start --web",
    "server:dev": "node --env-file=.env ./node_modules/tsx/dist/cli.mjs server/index.ts",
    "stt:python:setup": "python -m pip install -r server/python/requirements-stt.txt",
    "stt:python:diarization:setup": "python -m pip install -r server/python/requirements-stt-diarization-optional.txt",
    "expo:start:static:build": "set EXPO_NO_DOCTOR=1&& node ./node_modules/expo/bin/cli start --no-dev --minify --localhost",
    "expo:static:build": "node scripts/build.js",
    "server:build": "esbuild server/index.ts --platform=node --packages=external --bundle --format=cjs --outdir=server_dist",
    "server:prod": "node --env-file=.env server_dist/index.js",
    "db:push": "drizzle-kit push",
    "start": "set EXPO_NO_DOCTOR=1&& node ./node_modules/expo/bin/cli start",
    "lint": "expo lint",
    "lint:fix": "expo lint --fix"
  },
  "dependencies": {
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/drawer": "^7.8.1",
    "@tanstack/react-query": "^5.83.0",
    "axios": "^1.13.6",
    "drizzle-orm": "^0.39.3",
    "drizzle-zod": "^0.7.0",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-battery": "^55.0.8",
    "expo-constants": "~18.0.11",
    "expo-crypto": "^15.0.8",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.9",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.10",
    "expo-local-authentication": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-notifications": "~0.32.16",
    "expo-print": "^55.0.8",
    "expo-router": "~6.0.23",
    "expo-speech-recognition": "^3.1.0",
    "expo-splash-screen": "~31.0.12",
    "expo-status-bar": "~3.0.9",
    "expo-task-manager": "~14.0.9",
    "expo-web-browser": "~15.0.10",
    "express": "^5.0.1",
    "fs-extra": "^11.3.4",
    "lenis": "^1.3.17",
    "mysql2": "^3.18.2",
    "pg": "^8.16.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "^1.18.5",
    "react-native-maps": "1.20.1",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "tsx": "^4.20.6",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@expo/ngrok": "^4.1.0",
    "@types/express": "^5.0.0",
    "@types/fs-extra": "^11.0.4",
    "@types/react": "~19.1.10",
    "babel-plugin-react-compiler": "^19.0.0-beta-e993439-20250117",
    "drizzle-kit": "^0.31.4",
    "eas-cli": "^18.1.0",
    "eslint": "^9.31.0",
    "eslint-config-expo": "~10.0.0",
    "patch-package": "^8.0.0",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": ">=20 <23"
  },
  "private": true
}
